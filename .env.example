# ─── PrognoBeast Backend — Variables d'environnement ───────────────────────────
# Copier ce fichier en .env et remplir les valeurs

# Port d'écoute (Railway le définit automatiquement)
PORT=4000

# URL du front Vercel (sans slash final)
# Exemple prod : https://prognobeast.vercel.app
ALLOWED_ORIGIN=http://localhost:3000

# ── Base de données PostgreSQL (Railway) ─────────────────────────────────────
# Railway le génère automatiquement si vous ajoutez un plugin PostgreSQL
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# ── Auth JWT ─────────────────────────────────────────────────────────────────
# Générer : openssl rand -base64 64
JWT_SECRET=change-me-to-a-very-long-random-secret

# ── Compte admin initial (utilisé lors du seed) ───────────────────────────────
# Mot de passe du compte prognobeast@gmail.com
ADMIN_PASSWORD=Admin@PrognoBeast2024!

# ── Email (optionnel — décommenter si vous utilisez Resend) ──────────────────
# RESEND_API_KEY=re_xxxxxxxxxxxx

# ── Telegram Bot (optionnel — pour notifications contact) ────────────────────
# TELEGRAM_BOT_TOKEN=xxxxx:xxxxxxxxxxxxxxxxxxxxxxxx
# TELEGRAM_CHAT_ID=-1001234567890
